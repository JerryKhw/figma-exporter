{
  "name": "@jerrykhw/figma-exporter",
  "version": "3.2.3",
  "description": "Figma Exporter",
  "type": "module",
  "scripts": {
    "test": "pnpm run tsc && pnpm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "lint:check": "eslint \"src/**/*.{ts,tsx}\"",
    "tsc": "pnpm run tsc:main && pnpm run tsc:ui",
    "tsc:main": "tsc --noEmit -p src/plugin",
    "tsc:ui": "tsc --noEmit -p src/ui",
    "tsc:main:watch": "tsc --noEmit -p src/plugin --watch --preserveWatchOutput",
    "tsc:ui:watch": "tsc --noEmit -p src/ui --watch --preserveWatchOutput",
    "tsc:watch": "concurrently -n main,ui \"pnpm run tsc:main:watch\" \"pnpm run tsc:ui:watch\"",
    "build": "pnpm run build:ui && pnpm run build:main",
    "build:main": "node esbuild.js",
    "build:main:watch": "node esbuild.js --watch",
    "build:ui": "vite build --emptyOutDir=false",
    "build:ui:watch": "vite build --watch --emptyOutDir=false",
    "build:watch": "concurrently -n main,ui \"pnpm run build:main:watch\" \"pnpm run build:ui:watch\"",
    "dev": "concurrently -n main,ui \"pnpm run dev:main\" \"pnpm run dev:ui\"",
    "dev:main": "concurrently -n tsc,build \"pnpm run tsc:main:watch\" \"pnpm run build:main:watch\"",
    "dev:ui": "vite build --watch"
  },
  "author": {
    "name": "JERRY/JIHOON KIM",
    "email": "jerry@jerrykhw.dev",
    "url": "https://github.com/JerryKhw"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.123.0",
    "@preact/preset-vite": "^2.10.3",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "fflate": "^0.8.2",
    "globals": "^17.4.0",
    "lucide-react": "^0.576.0",
    "postcss": "^8.5.8",
    "preact": "^10.28.4",
    "prettier": "^3.8.1",
    "react": "npm:@preact/compat@^18.3.2",
    "react-dom": "npm:@preact/compat@^18.3.2",
    "superstruct": "^2.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vite-plugin-singlefile-compression": "^2.0.12",
    "webp-converter-browser": "^1.0.4",
    "zustand": "^5.0.11"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
